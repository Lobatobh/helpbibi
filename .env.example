# Help Bibi environment template
# Copy this file to .env on the VPS/Dokploy environment and replace placeholder values.
# Never commit real secrets.

# Runtime
NODE_ENV=production
NEXT_PUBLIC_APP_URL=https://example.com
NEXT_PUBLIC_SOCKET_URL=/
SOCKET_CORS_ORIGIN=https://example.com

# Database
# Production must use PostgreSQL. SQLite is only acceptable for local/staging smoke tests.
DATABASE_URL=postgresql://helpbibi:change_me@postgres:5432/helpbibi?schema=public
POSTGRES_DATABASE_URL=postgresql://helpbibi:change_me@postgres:5432/helpbibi?schema=public
POSTGRES_PASSWORD=change_me

# Auth/session
SESSION_SECRET=replace_with_a_random_64_char_secret
ADMIN_SEED_ENABLED=false

# Payments
PAYMENT_GATEWAY_PROVIDER=simulated
PAYMENT_WEBHOOK_SECRET=replace_with_a_random_webhook_secret

# Mercado Pago is prepared but not homologated. Keep empty unless validating sandbox intentionally.
MERCADO_PAGO_ACCESS_TOKEN=
MERCADO_PAGO_WEBHOOK_SECRET=

# Redis/rate limiting/audit
REDIS_URL=redis://redis:6379
REDIS_PASSWORD=change_me
RATE_LIMIT_BACKEND=redis
AUDIT_LOG_BACKEND=database

# Internal services
RESCUE_SERVICE_URL=http://rescue-service:3003
RESCUE_SERVICE_PORT=3003
