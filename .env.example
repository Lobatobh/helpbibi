# Help Bibi environment template.
# Copy these keys to Dokploy environment variables or a VPS .env file.
# Never commit real secrets.

# Runtime
NODE_ENV=production
NEXT_PUBLIC_APP_URL=
NEXT_PUBLIC_SOCKET_URL=/
SOCKET_CORS_ORIGIN=

# Database
# Production must use PostgreSQL. Do not use file:/ SQLite with NODE_ENV=production.
POSTGRES_PASSWORD=
DATABASE_URL=
POSTGRES_DATABASE_URL=

# Auth/session
SESSION_SECRET=
ADMIN_SEED_ENABLED=false

# Payments
PAYMENT_GATEWAY_PROVIDER=simulated
PAYMENT_WEBHOOK_SECRET=

# Mercado Pago is prepared but not homologated. Keep empty unless validating sandbox intentionally.
MERCADO_PAGO_ACCESS_TOKEN=
MERCADO_PAGO_WEBHOOK_SECRET=

# Redis/rate limiting/audit
REDIS_URL=redis://redis:6379
RATE_LIMIT_BACKEND=redis
AUDIT_LOG_BACKEND=database

# Internal services
RESCUE_SERVICE_URL=http://rescue:3003
RESCUE_SERVICE_PORT=3003
